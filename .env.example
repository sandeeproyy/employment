# ============================================
# AutoApply — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# --- Database ---
DATABASE_URL=postgresql+asyncpg://autoapply:autoapply@db:5432/autoapply
DATABASE_URL_SYNC=postgresql://autoapply:autoapply@db:5432/autoapply
POSTGRES_USER=autoapply
POSTGRES_PASSWORD=autoapply
POSTGRES_DB=autoapply

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- AI Provider (Google Gemini Free Tier) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- Application ---
APP_NAME=AutoApply
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-key
API_TOKEN=supersecret

# --- CORS ---
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- File Storage ---
UPLOAD_DIR=./uploads
GENERATED_DIR=./generated
